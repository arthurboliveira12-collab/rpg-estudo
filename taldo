        // Partículas ambientais de fundo
        const canvas = document.getElementById('ambient-canvas');
        const ctx = canvas.getContext('2d');
        let particles = [];

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Particle {
            constructor() { this.reset(); }
            reset() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 2 + 1;
                this.speedX = Math.random() * 0.4 - 0.2;
                this.speedY = Math.random() * 0.5 + 0.1;
                this.alpha = Math.random() * 0.5 + 0.2;
            }
            update() {
                this.y -= this.speedY;
                this.x += this.speedX;
                if (this.y < 0) {
                    this.reset();
                    this.y = canvas.height;
                }
            }
            draw() {
                ctx.fillStyle = `rgba(96, 165, 250, ${this.alpha})`;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        for (let i = 0; i < 40; i++) particles.push(new Particle());

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animate);
        }
        animate();

        // Controlos da Interface
        function iniciarJogo() {
            playSound('click');
            document.getElementById('intro-screen').classList.add('hidden');
            document.getElementById('game-screen').classList.remove('hidden');
            atualizarUI();
            carregarFase();
        }

        function atualizarUI() {
            const heartsContainer = document.getElementById('hearts-container');
            heartsContainer.innerHTML = '';
            for (let i = 0; i < state.maxHp; i++) {
                const mask = document.createElement('i');
                mask.className = `fa-solid fa-ghost text-2xl mask-icon ${i < state.hp ? 'text-slate-100' : 'mask-lost'}`;
                heartsContainer.appendChild(mask);
            }

            const soulFill = document.getElementById('soul-fill');
            soulFill.style.height = `${state.soul}%`;

            document.getElementById('nail-level').innerText = `Antigo Prego +${state.nail}`;
        }

        function carregarFase() {
            const phase = phases[state.currentPhase];
            
            document.getElementById('phase-badge').innerText = phase.badge;
            document.getElementById('phase-title').innerText = phase.title;
            document.getElementById('phase-illustration').innerHTML = phase.illustration;
            document.getElementById('story-text').innerText = phase.text;

            const choicesContainer = document.getElementById('choices-container');
            choicesContainer.innerHTML = '';

            phase.options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = "w-full text-left p-4 rounded bg-slate-900 hover:bg-blue-950/60 border border-slate-800 hover:border-blue-700 transition-all duration-200 text-sm md:text-base flex gap-3 items-center group";
                btn.innerHTML = `
                    <span class="w-8 h-8 rounded-full bg-slate-800 flex items-center justify-center font-bold text-blue-400 group-hover:bg-blue-500 group-hover:text-white transition-all duration-200">${opt.letter}</span>
                    <span class="flex-1 text-gray-300 group-hover:text-slate-100">${opt.desc}</span>
                `;
                btn.onclick = () => responder(opt);
                choicesContainer.appendChild(btn);
            });
        }

        function responder(opcao) {
            if (opcao.correct) {
                playSound('victory');
                state.soul = Math.min(100, state.soul + 25);
                state.nail += 1;
                
                document.getElementById('npc-text').innerText = `"Brilhante, Knight! O seu prego vibra com o fluxo invisível do magnetismo. Continua adiante!"`;
                
                state.currentPhase++;
                if (state.currentPhase < phases.length) {
                    atualizarUI();
                    carregarFase();
                } else {
                    fimDeJogo(true);
                }
            } else {
                playSound('damage');
                state.hp--;
                state.soul = Math.max(0, state.soul - 15);
                
                document.getElementById('npc-text').innerText = `"${opcao.explanation}"`;
                
                atualizarUI();

                if (state.hp <= 0) {
                    fimDeJogo(false);
                }
            }
        }

        function fimDeJogo(vitoria) {
            document.getElementById('game-screen').classList.add('hidden');
            document.getElementById('end-screen').classList.remove('hidden');

            const icon = document.getElementById('end-icon');
            const title = document.getElementById('end-title');
            const msg = document.getElementById('end-message');

            if (vitoria) {
                icon.innerHTML = '<i class="fa-solid fa-crown text-yellow-500 float-animation"></i>';
                title.innerText = "Santuário Conquistado!";
                title.className = "text-2xl md:text-3xl font-bold tracking-wider mb-4 text-yellow-400";
                msg.innerText = "Decifrou todas as propriedades invisíveis do Magnetismo, domou as forças de atração de Hollownest e conquistou o lendário Amuleto Magnético de Puro Ouro! O seu prego agora brilha com pura indução elétrica.";
            } else {
                icon.innerHTML = '<i class="fa-solid fa-skull-crossbones text-red-500"></i>';
                title.innerText = "A sua Alma Desvaneceu...";
                title.className = "text-2xl md:text-3xl font-bold tracking-wider mb-4 text-red-500";
                msg.innerText = "As forças magnéticas descontroladas arremessaram espinhos contra si. As suas máscaras partiram-se e regressou ao vazio das masmorras. Tente novamente para dominar a física!";
            }
        }

        function reiniciarJogo() {
            playSound('click');
            state.hp = 5;
            state.soul = 100;
            state.nail = 1;
            state.currentPhase = 0;
            
            document.getElementById('npc-text').innerText = `"Ah, jovem viajante... Este santuário é moldado por forças que não vemos. Estuda o magnetismo para não perecer."`;
            document.getElementById('end-screen').classList.add('hidden');
            document.getElementById('game-screen').classList.remove('hidden');
            
            atualizarUI();
            carregarFase();
        }
    </script>
</body>
</html>
